# box_system 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ===== 必须设置的变量（无默认值，未设置则服务无法启动） =====

# JWT 密钥 - 必须设置为强随机字符串（至少 32 字符）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-very-strong-random-secret-key-at-least-32-chars

# 默认管理员密码 - 首次启动时用于创建管理员账号
DEFAULT_ADMIN_PASSWORD=your-strong-admin-password

# ===== 可选变量（有默认值） =====

# vLLM 视觉模型服务地址
# VLLM_QWEN3VL_URL=http://localhost:8000

# CORS 允许的来源（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 摄像头页面视觉模型（容器内路径；宿主机挂载见 docker-compose.yml）
# YOLO_DETECT_MODEL_PATH=/models/runs/yolo26x_continue/weights/best.pt
# YOLO_CLASSIFY_MODEL_PATH=/models/disaster-classifier/best.pt
# YOLO_CLASSIFY_FALLBACK_PATH=

# Low-light pre-processing before YOLO inference. Auto mode only enhances dark frames.
# VISION_LOW_LIGHT_ENHANCE=true
# VISION_LOW_LIGHT_MODE=auto
# VISION_LOW_LIGHT_MEAN_THRESHOLD=72
# VISION_LOW_LIGHT_P10_THRESHOLD=45
# VISION_LOW_LIGHT_CLAHE_CLIP=2.2
# VISION_LOW_LIGHT_CLAHE_TILE=8
# VISION_LOW_LIGHT_GAMMA=0.72
# VISION_LOW_LIGHT_SHARPEN=0.18

# WebRTC Streamer（默认由 docker-compose.yml 启动并仅监听回环地址）
# WEBRTC_STREAMER_URL=http://127.0.0.1:8002
# WEBRTC_STREAM_OPTIONS=rtptransport=tcp&timeout=10

# 单路海康 RTSP 摄像头示例（建议 H.264 子码流）
# CAMERA_RTSP_URL=rtsp://用户名:密码@摄像头IP:554/Streaming/Channels/102
# CAMERA_ID=camera_001
# CAMERA_NAME=主摄像头

# 请求限制
# MAX_IMAGE_SIZE_MB=10

# IoTDB 配置
# IOTDB_HOST=127.0.0.1
# IOTDB_PORT=6667

# MySQL 配置
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=root
# MYSQL_DATABASE=dam_system

# JWT 配置
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_SECONDS=1296000

# 默认管理员用户名和真实姓名
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_REALNAME=管理员

# Redis 配置
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=redis

# MinIO / 文档存储
# MINIO_ENDPOINT=localhost:9000
# DOCUMENT_BUCKET=documents

# OnlyOffice / 文档编辑
# APP_PORT=8090
# PUBLIC_HOST=192.168.31.52
# BACKEND_PUBLIC_URL=http://192.168.31.52:8090
# ONLYOFFICE_PUBLIC_URL=http://192.168.31.52
# ONLYOFFICE_JWT_SECRET=your-onlyoffice-secret
# VITE_API_BASE_URL=http://192.168.31.52:8090
# VITE_ONLYOFFICE_URL=http://192.168.31.52
